# ================================================================
# 投資儀表板 — 環境變數設定
# 複製為 .env.local（本機開發用），或直接填入 Vercel 環境變數設定頁
# ================================================================

# ── Notion API Key ───────────────────────────────────────────────
# 取得步驟：
# 1. 前往 https://www.notion.so/my-integrations
# 2. 點「New integration」→ 填名稱 → 建立
# 3. 複製 Internal Integration Secret（格式：secret_xxx...）
NOTION_API_KEY=secret_在這裡填入你的金鑰

# ── Notion 資料庫 ID（已為你填入，直接複製即可）───────────────
NOTION_DB_TRANSACTIONS=efeec7d17c1647f4901ea34d5bb25c72
NOTION_DB_CASHFLOW=93d3c5d202c34952b26dd60943129a0c
NOTION_DB_HOLDINGS=da55c763359b42edb985b4dfdc9d41f6
NOTION_DB_SNAPSHOT=cd7bd1299dd24c33a030f239c257b481

# ── Cron 安全金鑰 ────────────────────────────────────────────────
# 自行設定任意字串，用於保護每日自動快照的 API 端點
# 例如：my-secret-abc123（只要不是空的就行）
CRON_SECRET=在這裡填入任意字串

# ── 匯率（選填，預設 32.0）──────────────────────────────────────
NEXT_PUBLIC_USD_TWD_RATE=32.0
